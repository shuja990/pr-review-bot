# Node environment
NODE_ENV=development

# Anthropic API key for Claude
ANTHROPIC_API_KEY=

# Bitbucket OAuth consumer credentials
BITBUCKET_CLIENT_ID=
BITBUCKET_CLIENT_SECRET=

# Session encryption secret (min 8 chars, use a strong random string)
SESSION_SECRET=

# App URL (frontend origin — used for CORS and OAuth redirect)
APP_URL=http://localhost:5173

# Secret for validating Bitbucket webhook payloads (optional)
WEBHOOK_SECRET=

# Server port
PORT=3001
